-- Registrar una venta
CREATE OR REPLACE PROCEDURE registrar_venta(
    p_arete VARCHAR,
    p_id_comprador INT,
    p_precio_kg DECIMAL(10,2),
    p_peso_kg DECIMAL(10,2),
    p_id_empleado INT
)
LANGUAGE plpgsql
AS $$
DECLARE
    v_id_venta INT;
    v_en_retiro BOOLEAN;
    v_corral INT;
BEGIN
    SELECT en_retiro(p_arete) INTO v_en_retiro;
    IF v_en_retiro THEN
        RAISE EXCEPTION 'Animal en periodo de retiro';
    END IF;
    
    SELECT id_corral_actual INTO v_corral
    FROM animales
    WHERE arete = p_arete;
    
    INSERT INTO ventas(id_comprador, precio_kg, peso_total, estatus)
    VALUES (p_id_comprador, p_precio_kg, p_peso_kg, 'Completado')
    RETURNING id_venta INTO v_id_venta;
    
    INSERT INTO venta_detalle(id_venta, arete, precio)
    VALUES (v_id_venta, p_arete, p_precio_kg * p_peso_kg);
    
    UPDATE animales
    SET id_estado = (SELECT id_estado FROM estado WHERE nombre = 'Vendido'),
        id_corral_actual = NULL
    WHERE arete = p_arete;
    
    INSERT INTO bitacora(id_empleado, accion, tabla_afectada, registro_id)
    VALUES (p_id_empleado, 'VENTA', 'ventas', v_id_venta::TEXT);
END;
$$;

-- Mover animal(es) de corral
CREATE OR REPLACE PROCEDURE mover_animal(
    p_arete VARCHAR,
    p_nuevo_corral INT,
    p_nueva_dieta INT,
    p_id_empleado INT
)
LANGUAGE plpgsql
AS $$
DECLARE
    v_capacidad INT;
    v_ocupacion INT;
BEGIN
    SELECT capacidad INTO v_capacidad
    FROM corrales
    WHERE id_corral = p_nuevo_corral;
    
    SELECT COUNT(*) INTO v_ocupacion
    FROM animales
    WHERE id_corral_actual = p_nuevo_corral
      AND fecha_muerte IS NULL;
    
    IF v_ocupacion >= v_capacidad THEN
        RAISE EXCEPTION 'Corral lleno';
    END IF;
    
    UPDATE animales
    SET id_corral_actual = p_nuevo_corral
    WHERE arete = p_arete;
    
    IF p_nueva_dieta IS NOT NULL THEN
        UPDATE corrales
        SET dieta_actual = p_nueva_dieta
        WHERE id_corral = p_nuevo_corral;
    END IF;
    
    INSERT INTO historial_eventos(arete, id_tipo, descripcion, id_empleado)
    VALUES(
        p_arete,
        (SELECT id_tipo FROM tipo_evento WHERE nombre = 'Movimiento'),
        'Cambio de corral',
        p_id_empleado
    );
END;
$$;

-- Registrar recepción de lote
CREATE OR REPLACE FUNCTION recepcion_lotes(
    n_numero_guia VARCHAR,
    n_id_proveedor INT,
    n_motivo TEXT,
    p_programados INT,
    p_recibidos INT,
    p_enfermos INT,
    p_id_empleado INT
)
RETURNS VOID
LANGUAGE plpgsql
AS $$
DECLARE
    v_id_guia INT;
BEGIN
    INSERT INTO guias_transito(numero_guia, id_proveedor, motivo)
    VALUES (n_numero_guia, n_id_proveedor, n_motivo)
    RETURNING id_guia INTO v_id_guia;
    
    INSERT INTO recepcion_lotes(id_guia, fecha_recepcion, animales_programados,
                                animales_recibidos, animales_muertos, animales_enfermos, id_empleado)
    VALUES (v_id_guia, CURRENT_DATE, p_programados, p_recibidos, 0, p_enfermos, p_id_empleado);
END;
$$;

-- Servir comida descontando ingredientes
CREATE OR REPLACE PROCEDURE servir_comida(
    p_corral INT,
    p_kg DECIMAL(10,2),
    p_id_empleado INT
)
LANGUAGE plpgsql
AS $$
DECLARE
    v_dieta INT;
    rec RECORD;
BEGIN
    SELECT dieta_actual INTO v_dieta
    FROM corrales
    WHERE id_corral = p_corral;
    
    FOR rec IN
        SELECT di.id_ingredientes, di.porcentaje
        FROM dieta_ingredientes di
        WHERE di.id_dieta = v_dieta
    LOOP
        IF (SELECT stock_actual FROM ingredientes WHERE id_ingredientes = rec.id_ingredientes) <
           (p_kg * rec.porcentaje / 100.0) THEN
            RAISE EXCEPTION 'Stock insuficiente del ingrediente %', rec.id_ingredientes;
        END IF;
    END LOOP;
    
    INSERT INTO servicios_alimentacion(id_corral, id_dieta, cantidad_kg, id_empleado)
    VALUES (p_corral, v_dieta, p_kg, p_id_empleado);
    
    UPDATE ingredientes i
    SET stock_actual = stock_actual - (p_kg * di.porcentaje / 100.0)
    FROM dieta_ingredientes di
    WHERE di.id_dieta = v_dieta
      AND di.id_ingredientes = i.id_ingredientes;
END;
$$;

-- Registro automático de recepción con creación de animales
CREATE OR REPLACE PROCEDURE registrar_recepcion(
    p_numero_guia VARCHAR,
    p_proveedor INT,
    p_corral INT,
    p_cantidad INT,
    p_id_empleado INT
)
LANGUAGE plpgsql
AS $$
DECLARE
    v_guia INT;
    i INT;
    v_estado_comprado INT;
BEGIN
    SELECT id_estado INTO v_estado_comprado FROM estado WHERE nombre = 'comprado';
    
    INSERT INTO guias_transito(numero_guia, id_proveedor, motivo)
    VALUES (p_numero_guia, p_proveedor, 'Recepción')
    RETURNING id_guia INTO v_guia;
    
    INSERT INTO recepcion_lotes(id_guia, animales_recibidos, id_empleado)
    VALUES (v_guia, p_cantidad, p_id_empleado);
    
    FOR i IN 1..p_cantidad LOOP
        INSERT INTO animales(arete, id_estado, sexo, peso_entrada, meses, precio_compra, id_corral_actual)
        VALUES (
            CONCAT('AUTO_', v_guia, '_', i),
            v_estado_comprado,
            'macho',
            200,
            12,
            1000,
            p_corral
        );
    END LOOP;
END;
$$;

-- Tratamiento masivo en un corral
CREATE OR REPLACE PROCEDURE tratamiento_masivo(
    p_corral INT,
    p_medicamento INT,
    p_id_empleado INT
)
LANGUAGE plpgsql
AS $$
DECLARE
    r RECORD;
    v_dosis DECIMAL(10,2);
BEGIN
    FOR r IN
        SELECT arete FROM animales
        WHERE id_corral_actual = p_corral
          AND fecha_muerte IS NULL
    LOOP
        SELECT dosis(p_medicamento, r.arete) INTO v_dosis;
        
        INSERT INTO tratamientos(arete, id_medicamento, dosis_aplicada, id_empleado)
        VALUES (r.arete, p_medicamento, v_dosis, p_id_empleado);
        
        UPDATE medicamentos
        SET stock_actual = stock_actual - v_dosis
        WHERE id_medicamento = p_medicamento;
    END LOOP;
END;
$$;

-- Sugerir reubicación (ejemplo)
CREATE OR REPLACE FUNCTION sugerir_reubicacion(p_corral INT)
RETURNS TABLE(
    corral_origen INT,
    corral_destino INT,
    animales_a_mover INT
)
LANGUAGE plpgsql
AS $$
DECLARE
    v_ocupacion INT;
BEGIN
    SELECT COUNT(*) INTO v_ocupacion
    FROM animales
    WHERE id_corral_actual = p_corral
      AND fecha_muerte IS NULL;
    
    RETURN QUERY
    SELECT
        p_corral,
        c2.id_corral,
        v_ocupacion
    FROM corrales c2
    WHERE c2.id_corral != p_corral
      AND c2.capacidad > v_ocupacion
    LIMIT 1;
END;
$$;

