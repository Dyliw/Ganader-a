-- Clasificación automática según sexo y meses
CREATE OR REPLACE FUNCTION clasificar_auto()
RETURNS TRIGGER
LANGUAGE plpgsql
AS $$
BEGIN
    IF NEW.meses IS NULL OR NEW.sexo IS NULL THEN
        NEW.clasificacion := NULL;
        RETURN NEW;
    END IF;
    
    NEW.clasificacion := CASE
        WHEN NEW.sexo = 'hembra' THEN
            CASE
                WHEN NEW.meses <= 15 THEN 'Becerra'
                WHEN NEW.meses <= 24 THEN 'Novilla'
                ELSE 'Vaca'
            END
        ELSE
            CASE
                WHEN NEW.meses <= 15 THEN 'Becerro'
                WHEN NEW.meses <= 24 THEN 'Novillo'  -- Aquí podrías necesitar castrado, se deja como ejemplo
                ELSE 'Toro'
            END
        END;
    RETURN NEW;
END;
$$;

CREATE TRIGGER trigger_clasificacion
BEFORE INSERT OR UPDATE OF meses, sexo
ON animales
FOR EACH ROW
EXECUTE FUNCTION clasificar_auto();

-- Calcular fecha disponible tras un tratamiento
CREATE OR REPLACE FUNCTION calcular_fecha_disponible()
RETURNS TRIGGER
LANGUAGE plpgsql
AS $$
DECLARE
    v_retiro INT;
    v_requiere BOOLEAN;
BEGIN
    SELECT retiro_dias, requiere_retiro INTO v_retiro, v_requiere
    FROM medicamentos
    WHERE id_medicamento = NEW.id_medicamento;
    
    IF v_requiere IS NULL THEN
        RAISE EXCEPTION 'Medicamento no encontrado';
    END IF;
    
    IF v_requiere THEN
        NEW.fecha_disponible := NEW.fecha_aplicacion + v_retiro;
    ELSE
        NEW.fecha_disponible := NEW.fecha_aplicacion;
    END IF;
    RETURN NEW;
END;
$$;

CREATE TRIGGER trigger_disponibilidad
BEFORE INSERT OR UPDATE OF id_medicamento, fecha_aplicacion
ON tratamientos
FOR EACH ROW
EXECUTE FUNCTION calcular_fecha_disponible();

-- Validar que el medicamento no esté caduco
CREATE OR REPLACE FUNCTION trg_validar_caducidad_medicamento()
RETURNS TRIGGER
LANGUAGE plpgsql
AS $$
DECLARE
    v_fecha_cad DATE;
BEGIN
    SELECT MAX(fecha_caducidad)
    INTO v_fecha_cad
    FROM entrada_almacen
    WHERE id_medicamento = NEW.id_medicamento;
    
    IF v_fecha_cad IS NOT NULL AND v_fecha_cad < CURRENT_DATE THEN
        RAISE EXCEPTION 'Medicamento caduco';
    END IF;
    RETURN NEW;
END;
$$;

CREATE TRIGGER tg_medicamento_caduco
BEFORE INSERT ON tratamientos
FOR EACH ROW
EXECUTE FUNCTION trg_validar_caducidad_medicamento();

-- Registro automático de cambio de corral en historial
CREATE OR REPLACE FUNCTION trg_movimiento_corral()
RETURNS TRIGGER
LANGUAGE plpgsql
AS $$
BEGIN
    IF NEW.id_corral_actual IS DISTINCT FROM OLD.id_corral_actual THEN
        INSERT INTO historial_eventos(arete, id_tipo, descripcion, id_empleado)
        VALUES(
            NEW.arete,
            (SELECT id_tipo FROM tipo_evento WHERE nombre = 'Movimiento'),
            CONCAT('De corral ', OLD.id_corral_actual, ' a ', NEW.id_corral_actual),
            NEW.creado_por
        );
    END IF;
    RETURN NEW;
END;
$$;

CREATE TRIGGER tg_movimiento_animal
AFTER UPDATE OF id_corral_actual ON animales
FOR EACH ROW
EXECUTE FUNCTION trg_movimiento_corral();

-- Validar retiro antes de venta
CREATE OR REPLACE FUNCTION trg_validar_venta_retiro()
RETURNS TRIGGER
LANGUAGE plpgsql
AS $$
BEGIN
    IF en_retiro(NEW.arete) THEN
        RAISE EXCEPTION 'Animal en periodo de retiro';
    END IF;
    RETURN NEW;
END;
$$;

CREATE TRIGGER tg_venta_retiro
BEFORE INSERT ON venta_detalle
FOR EACH ROW
EXECUTE FUNCTION trg_validar_venta_retiro();

-- Validar que la dieta del servicio coincida con la del corral
CREATE OR REPLACE FUNCTION trg_validar_dieta_corral()
RETURNS TRIGGER
LANGUAGE plpgsql
AS $$
DECLARE
    v_dieta INT;
BEGIN
    SELECT dieta_actual INTO v_dieta
    FROM corrales
    WHERE id_corral = NEW.id_corral;
    
    IF v_dieta IS NULL OR v_dieta != NEW.id_dieta THEN
        RAISE EXCEPTION 'La dieta no corresponde al corral';
    END IF;
    RETURN NEW;
END;
$$;

CREATE TRIGGER tg_dieta_corral
BEFORE INSERT ON servicios_alimentacion
FOR EACH ROW
EXECUTE FUNCTION trg_validar_dieta_corral();

-- Bloquear eliminación de animal con historial
CREATE OR REPLACE FUNCTION trg_bloquear_animal()
RETURNS TRIGGER
LANGUAGE plpgsql
AS $$
BEGIN
    IF EXISTS (SELECT 1 FROM tratamientos WHERE arete = OLD.arete)
       OR EXISTS (SELECT 1 FROM venta_detalle WHERE arete = OLD.arete) THEN
        RAISE EXCEPTION 'No se puede eliminar: tiene historial';
    END IF;
    RETURN OLD;
END;
$$;

CREATE TRIGGER tg_delete_animal
BEFORE DELETE ON animales
FOR EACH ROW
EXECUTE FUNCTION trg_bloquear_animal();

-- Alerta de stock mínimo
CREATE OR REPLACE FUNCTION trg_alerta_stock()
RETURNS TRIGGER
LANGUAGE plpgsql
AS $$
BEGIN
    IF NEW.stock_actual < NEW.stock_minimo THEN
        INSERT INTO alertas(tipo, mensaje)
        VALUES (
            'STOCK',
            CONCAT('Stock bajo en ingrediente ID ', NEW.id_ingredientes)
        );
    END IF;
    RETURN NEW;
END;
$$;
