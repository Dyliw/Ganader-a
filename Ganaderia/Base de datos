-- Dosis de medicamento según tipo
CREATE OR REPLACE FUNCTION dosis(p_medicamento INT, p_arete VARCHAR)
RETURNS DECIMAL(10,2)
LANGUAGE plpgsql
AS $$
DECLARE
    v_peso DECIMAL(10,2);
    v_tipo text;
    v_dosis_fija DECIMAL(10,2);
    v_dosis_kg DECIMAL(10,2);
BEGIN
    SELECT peso INTO v_peso
    FROM historial_peso
    WHERE arete = p_arete
    ORDER BY fecha DESC
    LIMIT 1;
    
    IF v_peso IS NULL THEN
        SELECT peso_entrada INTO v_peso
        FROM animales
        WHERE arete = p_arete;
    END IF;
    
    SELECT tipo_dosis, dosis_fija, dosis_kg
    INTO v_tipo, v_dosis_fija, v_dosis_kg
    FROM medicamentos
    WHERE id_medicamento = p_medicamento;
    
    IF v_tipo = 'Fija' THEN
        RETURN v_dosis_fija;
    ELSIF v_tipo = 'Proporcional' THEN
        RETURN v_dosis_kg * v_peso;
    ELSE
        RETURN NULL;
    END IF;
END;
$$;

-- ¿Está en periodo de retiro?
CREATE OR REPLACE FUNCTION en_retiro(p_arete VARCHAR)
RETURNS BOOLEAN
LANGUAGE plpgsql
AS $$
DECLARE
    v_fecha DATE;
BEGIN
    SELECT MAX(fecha_disponible)
    INTO v_fecha
    FROM tratamientos
    WHERE arete = p_arete;
    
    IF v_fecha IS NULL THEN
        RETURN FALSE;
    END IF;
    
    RETURN CURRENT_DATE < v_fecha;
END;
$$;

-- Días restantes de retiro
CREATE OR REPLACE FUNCTION dias_restantes(v_arete VARCHAR)
RETURNS INTEGER
LANGUAGE plpgsql
AS $$
DECLARE
    v_disponible DATE;
    v_dias INTEGER;
BEGIN
    SELECT MAX(fecha_disponible) INTO v_disponible
    FROM tratamientos
    WHERE arete = v_arete;
    
    IF v_disponible IS NOT NULL AND v_disponible > current_date THEN
        v_dias := v_disponible - CURRENT_DATE;
    ELSE
        v_dias := NULL;
    END IF;
    RETURN v_dias;
END;
$$;

-- Ocupación de un corral
CREATE OR REPLACE FUNCTION ocupacion_corral(p_corral INT)
RETURNS TABLE(
    capacidad INT,
    ocupacion INT,
    disponible INT,
    porcentaje DECIMAL
)
LANGUAGE plpgsql
AS $$
BEGIN
    RETURN QUERY
    SELECT
        c.capacidad,
        COUNT(a.arete)::INT AS ocupacion,
        c.capacidad - COUNT(a.arete)::INT AS disponible,
        (COUNT(a.arete) * 100.0 / c.capacidad)::DECIMAL AS porcentaje
    FROM corrales c
    LEFT JOIN animales a
        ON a.id_corral_actual = c.id_corral
        AND a.fecha_muerte IS NULL
    WHERE c.id_corral = p_corral
    GROUP BY c.capacidad;
END;
$$;

-- Edad en días desde ingreso
CREATE OR REPLACE FUNCTION edad_dietas(p_arete VARCHAR)
RETURNS INT
LANGUAGE plpgsql
AS $$
DECLARE
    v_fecha DATE;
BEGIN
    SELECT fecha_ingreso INTO v_fecha
    FROM animales
    WHERE arete = p_arete;
    
    IF v_fecha IS NULL THEN
        RETURN NULL;
    END IF;
    
    RETURN CURRENT_DATE - v_fecha;
END;
$$;

-- Ganancia diaria de peso
CREATE OR REPLACE FUNCTION ganancia_diaria(p_arete VARCHAR)
RETURNS DECIMAL(10,4)
LANGUAGE plpgsql
AS $$
DECLARE
    v_peso_inicial DECIMAL(10,2);
    v_peso_final DECIMAL(10,2);
    v_fecha_inicial DATE;
    v_fecha_final DATE;
    v_dias INT;
BEGIN
    SELECT peso, fecha
    INTO v_peso_inicial, v_fecha_inicial
    FROM historial_peso
    WHERE arete = p_arete
    ORDER BY fecha ASC
    LIMIT 1;
    
    SELECT peso, fecha
    INTO v_peso_final, v_fecha_final
    FROM historial_peso
    WHERE arete = p_arete
    ORDER BY fecha DESC
    LIMIT 1;
    
    IF v_peso_inicial IS NULL OR v_peso_final IS NULL THEN
        RETURN NULL;
    END IF;
    
    v_dias := v_fecha_final - v_fecha_inicial;
    IF v_dias <= 0 THEN
        RETURN NULL;
    END IF;
    
    RETURN (v_peso_final - v_peso_inicial) / v_dias;
END;
$$;

-- Costo por kg de dieta
CREATE OR REPLACE FUNCTION costo_dieta(p_id_dieta INT)
RETURNS DECIMAL(10,2)
LANGUAGE plpgsql
AS $$
DECLARE
    v_costo_total DECIMAL(10,2);
BEGIN
    SELECT SUM((di.porcentaje/100.0) * i.precio_unitario)
    INTO v_costo_total
    FROM dieta_ingredientes di
    JOIN ingredientes i ON di.id_ingredientes = i.id_ingredientes
    WHERE di.id_dieta = p_id_dieta;
    
    RETURN COALESCE(v_costo_total, 0);
END;
$$;

-- Calcular comida necesaria para un corral en una fecha
CREATE OR REPLACE FUNCTION calcular_comida(p_id_corral INT, p_fecha DATE)
RETURNS DECIMAL(10,2)
LANGUAGE plpgsql
AS $$
DECLARE
    v_total DECIMAL(10,2);
    v_factor FLOAT;
    v_peso_total DECIMAL(10,2);
BEGIN
    SELECT d.factor INTO v_factor
    FROM corrales c
    JOIN dietas d ON c.dieta_actual = d.id_dieta
    WHERE c.id_corral = p_id_corral;
    
    IF v_factor IS NULL THEN
        RETURN NULL;
    END IF;
    
    SELECT SUM(COALESCE(hp.peso, a.peso_entrada))
    INTO v_peso_total
    FROM animales a
    LEFT JOIN LATERAL (
        SELECT h.peso
        FROM historial_peso h
        WHERE h.arete = a.arete
          AND h.fecha <= p_fecha
        ORDER BY h.fecha DESC
        LIMIT 1
    ) hp ON true
    WHERE a.id_corral_actual = p_id_corral
      AND a.fecha_muerte IS NULL;
    
    IF v_peso_total IS NULL THEN
        RETURN 0;
    END IF;
    
    RETURN v_peso_total * v_factor;
END;
$$;

