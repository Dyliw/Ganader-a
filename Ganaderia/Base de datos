create table estado(
    id_estado SERIAL primary key,
    nombre VARCHAR(50) not null,
    descripcion text
);

create table puestos(
    id_puesto SERIAL primary key,
    nombre VARCHAR(50) not null unique,
    descripcion text
);

create table tipo_corral(
    id_tipo serial primary key,
    nombre VARCHAR(30) not null unique,
    descripcion text
);

create table dietas(
    id_dieta SERIAL primary key,
    nombre VARCHAR(30) not null,
    factor FLOAT,
    descripcion text,
    activo BOOLEAN default true
);

create table ingredientes(
    id_ingredientes SERIAL primary key,
    nombre VARCHAR(20) not null,
    unidad_medida VARCHAR(10) not null,
    stock_actual DECIMAL(10,2) default 0,
    stock_minimo DECIMAL (10,2) default 0,
    precio_unitario DECIMAL(10,2) default 0,
    activo BOOLEAN DEFAULT true
);

create table dieta_ingredientes(
    id_dieta int not null references dietas(id_dieta),
    id_ingredientes int not null references ingredientes(id_ingredientes),
    porcentaje DECIMAL(5,2) not null check(porcentaje>0),
    PRIMARY KEY (id_dieta, id_ingredientes)
);

create table tipo_medicamento(
    id_tipo SERIAL primary key,
    nombre VARCHAR(20) not null,
    descripcion text
);

create table medicamentos(
    id_medicamento SERIAL primary key,
    nombre VARCHAR(80) not null,
    tipo_dosis TEXT not null CHECK(tipo_dosis in('Fija', 'Proporcional')),
    dosis_fija DECIMAL(10,2),
    dosis_kg DECIMAL(10,4),               -- dosis por kg
    base_peso DECIMAL(10,4),
    requiere_retiro BOOLEAN default false,
    id_tipo_medicamento INT not null references tipo_medicamento(id_tipo),
    retiro_dias int default 0,
    stock_actual DECIMAL(10,2) default 0,
    stock_minimo DECIMAL(10,2) default 0,
    unidad_medida VARCHAR(20) not null,
    activo BOOLEAN default true,
    CHECK (
        (tipo_dosis = 'Fija' AND dosis_fija IS NOT NULL AND dosis_kg IS NULL)
        OR
        (tipo_dosis = 'Proporcional' AND dosis_kg IS NOT NULL AND dosis_fija IS NULL)
    )
);

create table corrales(
    id_corral SERIAL primary key,
    nombre VARCHAR(20) not null,
    capacidad int not null check(capacidad>=0),
    id_tipo_corral int not null references tipo_corral(id_tipo),
    dieta_actual int not null references dietas(id_dieta),
    activo BOOLEAN default true
);
create table roles(
id_rol SERIAL primary key,
nombre VARCHAR(30) unique not null,
descripcion text
);
create table proveedores(
    id_proveedor SERIAL primary key,
    nombre VARCHAR(60) not null,
    apellido_paterno VARCHAR(50),
    apellido_materno VARCHAR(50),
    rfc VARCHAR(13) UNIQUE,
    telefono VARCHAR(20),
    direccion TEXT,
    activo BOOLEAN default true
);

create table empleados(
    id_empleado SERIAL primary key,
    nombre VARCHAR(60) not null,
    apellido_paterno VARCHAR(50) not null,
    apellido_materno VARCHAR(50),
    rfc VARCHAR(13) not null,
    id_puesto int not null references puestos(id_puesto),
    usuario VARCHAR(20) unique not null,
    contrasena VARCHAR(10) not null,          -- se recomienda aumentar longitud para hash
    activo BOOLEAN default true,
    fecha_contrato date default CURRENT_DATE,
    observaciones text
);

